# Copy to .env.local and adjust as needed.
# If left blank, defaults below kick in.

# ----- A/B test config -----
# Which Space to call. Flip this to switch arms. Restart `npm run dev` after
# changing — Vite only reads env vars at startup.
#
#   Arm A — two-stage (YOLOv8 + EfficientNetV2)
#     VITE_HF_SPACE=ontesla2020/trashsmartapp1
#
#   Arm B — YOLOv8 single-stage
#     VITE_HF_SPACE=ontesla2020/trashsmartapp2
VITE_HF_SPACE=ontesla2020/trashsmartapp1

# Human-readable label for the current arm. Shown as a badge on the scan
# result screen and stored in scan history so you can compare runs later.
VITE_MODEL_ARM=A · two-stage

# Optional. Only needed if your Space is private.
# Get a token at https://huggingface.co/settings/tokens
VITE_HF_TOKEN=
